/* Waybar Modules Extras */

/* This is where you can add Extra Modules you wish. copy.sh will try to restore*/
/* this file along with the unique configs and styles. */
/* IMPORTANT, be mindful with , or ". else waybar will not start */

{

"custom/qs_dashboard": {
        "format": "☰",
        "on-click": "if pgrep -x quickshell >/dev/null; then qs ipc call dashboard toggle; else quickshell >/dev/null 2>&1 & sleep 0.6; qs ipc call dashboard toggle; fi",
        "tooltip": true,
        "tooltip-format": "QuickShell Dashboard"
},

"custom/qs_dashboard_top": {
        "format": "☰",
        "on-click": "if pgrep -x quickshell >/dev/null; then qs ipc call toppanel toggle; else quickshell >/dev/null 2>&1 & sleep 0.6; qs ipc call toppanel toggle; fi",
        "tooltip": true,
        "tooltip-format": "QuickShell Dashboard"
},

"custom/power_button": {
        "format": "⏻",
        "on-click": "$HOME/.config/hypr/UserScripts/PowerMenuRofi.sh",
        "tooltip": true,
        "tooltip-format": "Power Menu (Rofi)"
}

}