# skwd-wall runtime environment
# Fill these values with your own API keys.

# Steam Workshop API key (optional unless you use Steam browser/download)
STEAM_API_KEY=

# Wallhaven API key (optional, needed for private/sensitive filters and higher limits)
WALLHAVEN_API_KEY=

# Optional override for Ollama endpoint
# SKWD_OLLAMA_URL=http://localhost:11434
